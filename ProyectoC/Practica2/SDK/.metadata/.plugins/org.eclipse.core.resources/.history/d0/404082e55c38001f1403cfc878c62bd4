	 int i = 0;
	 while(i < 100000);
	 INFRARROJOS_mWriteReg(XPAR_INFRARROJOS_0_BASEADDR, 0, 0);
 }

void apagarDotMatrix(){
	u32 Data = 0;
	int fila = 0;
	int columna = 0;
	int dato = 0;
	while(fila < 8) {
		columna = 0;
		while(columna < 7) {
			Data=((fila&0xff)<<(31-7))+((columna&0xff)<<(31-15))+((dato&0xff)<<(31-23));
			while(MATRIZ_DE_PUNTOS_mWriteFIFOFull(XPAR_MATRIZ_DE_PUNTOS_0_BASEADDR));
			MATRIZ_DE_PUNTOS_mWriteToFIFO(XPAR_MATRIZ_DE_PUNTOS_0_BASEADDR, 0, Data);
			columna++;
		}
		fila++;
	}
}


