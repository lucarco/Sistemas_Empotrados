void pruebaRGB(){
	int i = 0, j= 0, k= 0;
while(i < 255){
	while(j < 255){
		while(k < 255){
			LEDS_RGB_mWriteSlaveReg0(XPAR_LEDS_RGB_0_BASEADDR, 0, k);
			k++;
			int z = 0;
			while (z<10000) z++;
		}
		LEDS_RGB_mWriteSlaveReg1(XPAR_LEDS_RGB_0_BASEADDR, 0, j);
		j++;
	}
	LEDS_RGB_mWriteSlaveReg2(XPAR_LEDS_RGB_0_BASEADDR, 0, i);
	i++;
}
}

