#include <xstatus.h>
#include <stdlib.h>

/*
* LEDs; configured as Salida
* SWITCHes; configured as Entrada
*/

#define XPAR_RS232_UART_1_BASEADDR 0x84000000

int getNumber (){
    Xuint8 byte;
    Xuint8 uartBuffer[16];
    Xboolean validNumber;
    int digitIndex;
    int digit, number, sign;
    int c;

    while(1){
        byte = 0x00;
        digit = 0;
        digitIndex = 0;
        number = 0;
        validNumber = XTRUE;

        //get bytes from uart until RETURN is entered

        while(byte != 0x0d && byte != 0x0A){
            byte = XUartLite_RecvByte(XPAR_RS232_UART_1_BASEADDR);
            uartBuffer[digitIndex] = byte;
            XUartLite_SendByte(XPAR_RS232_UART_1_BASEADDR,byte);
            digitIndex++;
        }

        //calculate number from string of digits
        for(c = 0; c < (digitIndex - 1); c++){
            if(c == 0){
                //check if first byte is a "-"
                if(uartBuffer[c] == 0x2D){
                sign = -1;
                digit = 0;
            }

            //check if first byte is a digit
            else if((uartBuffer[c] >> 4) == 0x03){
                sign = 1;
                digit = (uartBuffer[c] & 0x0F);
            }
            else
                validNumber = XFALSE;
            }
            else{
                //check byte is a digit
                if((uartBuffer[c] >> 4) == 0x03){
                    digit = (uartBuffer[c] & 0x0F);
                }
                else
                    validNumber = XFALSE;
            }
            number = (number * 10) + digit;
        }
        number *= sign;

        if(validNumber == XTRUE){
            return number;
        }
        print("This is not a valid number.\n\r");
    }
}



int main()
{
	int operando1 = 0, operando2 = 0, resta = 0;
	int terminar = 0;
	char opcion;


    while(terminar == 0){
        print(" MENU: \n\r");
        print(" a - Introducir primer operando. \n\r");
        print(" b - Introducir segundo operando. \n\r");
        print(" c - Restar y visualizar el resultado en los leds y en la pantalla. \n\r");
        print(" d - Lectura de los Switches. \n\r");
        print(" e - Salir \n\r");

        opcion = XUartLite_RecvByte(XPAR_RS232_UART_1_BASEADDR);
        XUartLite_SendByte(XPAR_RS232_UART_1_BASEADDR,opcion);
        print("\r\n");

        if (opcion == 'a'){
            XGpio GPIO_LEDs;

            print("Introduce un numero\n\r");
            operando1 = getNumber();
            print("\r\n");

            XGpio_Initialize(&GPIO_LEDs, XPAR_XPS_GPIO_0_DEVICE_ID);
            XGpio_SetDataDirection(&GPIO_LEDs, 1, 0x00000000);
            XGpio_DiscreteWrite(&GPIO_LEDs, 1, operando1);
        }
        else if (opcion == 'b'){
            print("Introduce un numero\n\r");
            operando2 = getNumber();
            print("\r\n");

            XGpio GPIO_LEDs;

            XGpio_Initialize(&GPIO_LEDs, XPAR_XPS_GPIO_0_DEVICE_ID);
            XGpio_SetDataDirection(&GPIO_LEDs, 1, 0x00);
            XGpio_DiscreteWrite(&GPIO_LEDs, 1, operando2);
        }
        else if (opcion == 'c'){
            print("Resultado\n\r");
            resta = operando1 - operando2;
            xil_printf("El resultado es: %d\n\r", resta);

            XGpio GPIO_LEDs;
            XGpio_Initialize(&GPIO_LEDs, XPAR_XPS_GPIO_0_DEVICE_ID);
            XGpio_SetDataDirection(&GPIO_LEDs, 1, 0x00);
            XGpio_DiscreteWrite(&GPIO_LEDs, 1, resta);
        }
        else if (opcion == 'd'){
            XGpio GPIO_LEDs;
            XGpio GPIO_SWITCHes;

            //0
            XGpio_Initialize(&GPIO_LEDs, XPAR_XPS_GPIO_0_DEVICE_ID);
            XGpio_SetDataDirection(&GPIO_LEDs, 1, 0x00);

            // 1
            XGpio_Initialize(&GPIO_SWITCHes, XPAR_XPS_GPIO_1_DEVICE_ID);
            XGpio_SetDataDirection(&GPIO_SWITCHes, 1, 0xFF);

            u32 Data = XGpio_DiscreteRead(&GPIO_SWITCHes, 1);
            XGpio_DiscreteWrite(&GPIO_LEDs, 1, Data);
            xil_printf("Switches: %d\n\r", Data);
            print("\r\n");
        }
        else if (opcion == 'e'){
            print("Saliendo\n\r");
            terminar = 1;
        }
        else{
            print("dato incorrecto \n\r");
        }
    }
    print("-- Exiting main() --\r\n");
    return 0;
}
